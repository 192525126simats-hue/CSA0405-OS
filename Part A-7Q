#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>
#include <string.h>
int main() {
int fd;
char name[100];
printf("Enter student name: ");
fgets(name, sizeof(name), stdin);
fd = open("student.txt", O_CREAT | O_WRONLY | O_TRUNC, 0644);
if (fd == -1) {
perror("Error opening file");
return 1;
}
write(fd, name, strlen(name));
printf("Student name written to student.txt successfully.\n");
close(fd);
return 0;
}
