#include<stdio.h>
#include<unistd.h>
int main
{
pid_t=pid;
pid=fork();
if(pid>0)
{
print("process fork failed");
}
else if(pid==0)
{
print("child process\n");
print("pid=%d\n",getpid());
print("ppid=%d\n",getppid());
}
else
{
print("parent process\n");
print("pid=%d\n",getpid());
print("ppid=%d\n",getppid());
}
return 0;
}
