#include<stdio.h>
#include<stdlib.h>
#include<unistd.h>
#include<sys/types.h>
#include<sys/wait.h>
int main()
{
pid_t pid;
pid=fork();
if (pid<0)
{
printf("Fork failed:\n");
}
else if(pid==0)
printf("child pid:%d\n",getpid());
printf("child process is terminating...\n");
exit(0);
}
else
{
wait(NULL);
printf("parent process:child  has finished\n");
printf("parent process is completed",getppid());
}
return 0;
}
