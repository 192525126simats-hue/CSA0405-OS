#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>
#include <sys/types.h>
#include <sys/stat.h>
int main() {
int fd;
fd = open("student.txt", O_CREAT | O_RDWR, 0644);
if (fd == -1) {
perror("Error creating file");
return 1;
}
printf("File 'student.txt' created successfully.\n");
close(fd);
return 0;
}
