#include <stdio.h>
#include <unistd.h>
#include <sys/types.h>
int main()
{
int i;
for (i = 1; i <= 3; i++)
{
pid_t pid = fork();
if (pid < 0)
{
printf("Fork failed!\n");
return 1;
}
else if (pid == 0)
{
printf("Child %d: PID = %d, PPID = %d\n",i, getpid(), getppid());
return 0;
}
}
printf("Parent: PID = %d\n", getpid());
return 0;
}
